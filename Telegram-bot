async def withdraw_callback(update: Update, context):

    q = update.callback_query
    await q.answer()

    if q.from_user.id != ADMIN_ID:
        return

    data = q.data.split("_")

    action = data[0]
    user_id = int(data[1])
    amount = int(data[2])

    # ACCEPT
    if action == "accept":

        # USER WALLET
        wallet = cur.execute(
            "SELECT wallet FROM users WHERE user_id=?",
            (user_id,)
        ).fetchone()[0]

        try:

            # API URL
            url = f"https://ultra-pay.store/APIs/api?token={ULTRA_TOKEN}&key={ULTRA_KEY}&paytoNumber={wallet}&amount={amount}&comment=Withdraw"

            # REQUEST
            r = requests.get(url)

            # DEBUG
            print(r.status_code)
            print(r.text)

            result = r.text

            # SUCCESS MESSAGE
            await context.bot.send_message(
                user_id,
                f"""
✅ Withdraw Success

💰 Amount : ₹{amount}
🏦 Wallet : {wallet}
                """
            )

            # ADMIN RESULT
            await q.edit_message_text(
                f"✅ Payment Sent\n{result}"
            )

        except Exception as e:

            # REFUND
            cur.execute(
                "UPDATE users SET balance=balance+? WHERE user_id=?",
                (amount, user_id)
            )

            conn.commit()

            await context.bot.send_message(
                user_id,
                "❌ Payment Failed\n💰 Refund Added"
            )

            await q.edit_message_text(
                f"❌ API ERROR\n{e}"
            )

    # REJECT
    elif action == "reject":

        cur.execute(
            "UPDATE users SET balance=balance+? WHERE user_id=?",
            (amount, user_id)
        )

        conn.commit()

        await context.bot.send_message(
            user_id,
            f"❌ Withdraw Rejected\n💰 Refund ₹{amount}"
        )

        await q.edit_message_text(
            "❌ Rejected"
        )

