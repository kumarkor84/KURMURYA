def board_ui(board, prefix):

    keyboard = []

    for i in range(0, 9, 3):

        row = []

        for j in range(3):

            index = i + j

            value = board[index]

            if value == " ":
                value = "⬜"

            row.append(
                InlineKeyboardButton(
                    text=value,
                    callback_data=f"{prefix}_{index}"
                )
            )

        keyboard.append(row)

    return InlineKeyboardMarkup(keyboard)

