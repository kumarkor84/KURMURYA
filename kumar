# ================= ALL TEXT =================
async def all_text(update: Update, context):

    uid = update.effective_user.id
    txt = update.message.text

    # ================= ADMIN ADD =================
    if uid == ADMIN_ID and context.user_data.get("admin_add"):

        try:

            user_id = int(txt.split()[0])
            amount = int(txt.split()[1])

            user = cur.execute(
                "SELECT * FROM users WHERE user_id=?",
                (user_id,)
            ).fetchone()

            if not user:

                cur.execute(
                    "INSERT INTO users(user_id,balance) VALUES(?,?)",
                    (user_id,0)
                )

            cur.execute(
                "UPDATE users SET balance=balance+? WHERE user_id=?",
                (amount,user_id)
            )

            conn.commit()

            bal = cur.execute(
                "SELECT balance FROM users WHERE user_id=?",
                (user_id,)
            ).fetchone()[0]

            await update.message.reply_text(
                f"""
✅ BALANCE ADDED

👤 USER : {user_id}

💰 ADD : ₹{amount}

🏦 BALANCE : ₹{bal}
"""
            )

            try:

                await context.bot.send_message(
                    user_id,
                    f"""
💰 ADMIN ADDED

➕ ₹{amount}

🏦 Balance : ₹{bal}
"""
                )

            except:
                pass

        except:

            await update.message.reply_text(
                "❌ Wrong Format"
            )

        context.user_data["admin_add"] = False
        return

    # ================= ADMIN CUT =================
    if uid == ADMIN_ID and context.user_data.get("admin_cut"):

        try:

            user_id = int(txt.split()[0])
            amount = int(txt.split()[1])

            user = cur.execute(
                "SELECT balance FROM users WHERE user_id=?",
                (user_id,)
            ).fetchone()

            if not user:

                await update.message.reply_text(
                    "❌ User Not Found"
                )

                return

            balance = user[0]

            if balance < amount:

                await update.message.reply_text(
                    "❌ Low User Balance"
                )

                return

            cur.execute(
                "UPDATE users SET balance=balance-? WHERE user_id=?",
                (amount,user_id)
            )

            conn.commit()

            bal = cur.execute(
                "SELECT balance FROM users WHERE user_id=?",
                (user_id,)
            ).fetchone()[0]

            await update.message.reply_text(
                f"""
❌ BALANCE CUT

👤 USER : {user_id}

💸 CUT : ₹{amount}

🏦 BALANCE : ₹{bal}
"""
            )

            try:

                await context.bot.send_message(
                    user_id,
                    f"""
❌ ADMIN CUT

➖ ₹{amount}

🏦 Balance : ₹{bal}
"""
                )

            except:
                pass

        except:

            await update.message.reply_text(
                "❌ Wrong Format"
            )

        context.user_data["admin_cut"] = False
        return

    # ================= SAVE WALLET =================
    if context.user_data.get("wallet"):

        cur.execute(
            "UPDATE users SET wallet=? WHERE user_id=?",
            (txt, uid)
        )

        conn.commit()

        context.user_data["wallet"] = False

        await update.message.reply_text(
            "✅ Wallet Saved"
        )

        return

    # ================= WITHDRAW =================
    if context.user_data.get("withdraw"):

        if not txt.isdigit():

            await update.message.reply_text(
                "❌ Send Number"
            )

            return

        amount = int(txt)

        data = cur.execute(
            "SELECT balance,wallet FROM users WHERE user_id=?",
            (uid,)
        ).fetchone()

        balance_user = data[0]
        wallet = data[1]

        if amount > balance_user:

            await update.message.reply_text(
                "❌ Low Balance"
            )

            return

        if not wallet:

            await update.message.reply_text(
                "❌ Save Wallet First"
            )

            return

        cur.execute(
            "UPDATE users SET balance=balance-? WHERE user_id=?",
            (amount, uid)
        )

        conn.commit()

        wtype = context.user_data["type"]

        await context.bot.send_message(
            ADMIN_ID,
            f"""
💸 WITHDRAW REQUEST

👤 USER : {uid}

💰 AMOUNT : ₹{amount}

🏦 WALLET : {wallet}

📤 TYPE : {wtype}
"""
        )

        context.user_data["withdraw"] = False

        await update.message.reply_text(
            "✅ Withdraw Request Sent"
        )

        return

