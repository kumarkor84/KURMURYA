# ================= JOIN ROOM =================
async def join_game(update: Update, context):

    q = update.callback_query
    await q.answer()

    uid = q.from_user.id

    if len(rooms) == 0:

        await q.message.reply_text(
            "❌ No Room Found"
        )

        return

    room_id = list(rooms.keys())[0]

    room = rooms[room_id]

    if room["player2"] is not None:

        await q.message.reply_text(
            "❌ Room Full"
        )

        return

    if uid == room["player1"]:

        await q.message.reply_text(
            "❌ Own Room"
        )

        return

    bal = cur.execute(
        "SELECT balance FROM users WHERE user_id=?",
        (uid,)
    ).fetchone()[0]

    if bal < 1:

        await q.message.reply_text(
            "❌ Need ₹1 Balance"
        )

        return

    # CUT BALANCE
    cur.execute(
        "UPDATE users SET balance=balance-1 WHERE user_id=?",
        (room["player1"],)
    )

    cur.execute(
        "UPDATE users SET balance=balance-1 WHERE user_id=?",
        (uid,)
    )

    conn.commit()

    room["player2"] = uid

    text = """
🎮 USER VS USER START

⭕ Player1 = O
❌ Player2 = X

🏆 Winner Reward : ₹2
"""

    m1 = await context.bot.send_message(
        room["player1"],
        text,
        reply_markup=board_ui(
            room["board"],
            "room"
        )
    )

    m2 = await context.bot.send_message(
        uid,
        text,
        reply_markup=board_ui(
            room["board"],
            "room"
        )
    )

    room["msg1"] = m1.message_id
    room["msg2"] = m2.message_id

# ================= ROOM MOVE =================
async def room_move(update: Update, context):

    q = update.callback_query
    await q.answer()

    uid = q.from_user.id

    room = None

    for r in rooms.values():

        if uid == r["player1"] or uid == r["player2"]:

            room = r
            break

    if room is None:
        return

    if room["player2"] is None:
        return

    if room["turn"] != uid:

        await q.answer(
            "❌ Wait Your Turn",
            show_alert=True
        )

        return

    board = room["board"]

    pos = int(q.data.split("_")[1])

    if board[pos] != " ":
        return

    symbol = "O"

    if uid == room["player2"]:
        symbol = "X"

    board[pos] = symbol

    # ================= WIN =================
    if check(board,symbol):

        cur.execute(
            "UPDATE users SET balance=balance+2 WHERE user_id=?",
            (uid,)
        )

        conn.commit()

        loser = room["player1"]

        if uid == room["player1"]:
            loser = room["player2"]

        await context.bot.send_message(
            uid,
            "🎉 YOU WIN ₹2"
        )

        await context.bot.send_message(
            loser,
            "❌ YOU LOSE"
        )

        del rooms[room["player1"]]
        return

    # ================= DRAW =================
    if " " not in board:

        await context.bot.send_message(
            room["player1"],
            "🤝 MATCH DRAW"
        )

        await context.bot.send_message(
            room["player2"],
            "🤝 MATCH DRAW"
        )

        del rooms[room["player1"]]
        return

    # ================= CHANGE TURN =================
    if uid == room["player1"]:
        room["turn"] = room["player2"]
    else:
        room["turn"] = room["player1"]

    # ================= UPDATE BOTH =================
    await context.bot.edit_message_reply_markup(
        chat_id=room["player1"],
        message_id=room["msg1"],
        reply_markup=board_ui(board,"room")
    )

    await context.bot.edit_message_reply_markup(
        chat_id=room["player2"],
        message_id=room["msg2"],
        reply_markup=board_ui(board,"room")
    )

