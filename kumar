# ================= CHECK WIN =================
def check(board,p):

    wins = [
        (0,1,2),
        (3,4,5),
        (6,7,8),
        (0,3,6),
        (1,4,7),
        (2,5,8),
        (0,4,8),
        (2,4,6)
    ]

    for a,b,c in wins:

        if board[a]==board[b]==board[c]==p:
            return True

    return False

# ================= BOARD UI =================
def board_ui(board,prefix):

    keyboard = []

    for i in range(0,9,3):

        row = []

        for j in range(3):

            value = board[i+j]

            if value == " ":
                value = "⬜"

            row.append(
                InlineKeyboardButton(
                    value,
                    callback_data=f"{prefix}_{i+j}"
                )
            )

        keyboard.append(row)

    return InlineKeyboardMarkup(keyboard)

