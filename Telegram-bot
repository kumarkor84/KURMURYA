# =========================================================
#                    OX BOT MOVE
# =========================================================

async def bot_move(update: Update, context):

    q = update.callback_query
    await q.answer()

    uid = q.from_user.id

    if uid not in bot_games:
        return

    board = bot_games[uid]

    pos = int(q.data.split("_")[1])

    if board[pos] != " ":
        return

    # USER MOVE
    board[pos] = "O"

    # USER WIN
    if check(board, "O"):

        await q.edit_message_text(
            "🎉 YOU WIN"
        )

        del bot_games[uid]

        return

    # =========================================
    # BOT AI
    # =========================================

    move = None

    # 1. BOT WIN MOVE
    for i in range(9):

        if board[i] == " ":

            test = board.copy()
            test[i] = "X"

            if check(test, "X"):

                move = i
                break

    # 2. BLOCK USER WIN
    if move is None:

        for i in range(9):

            if board[i] == " ":

                test = board.copy()
                test[i] = "O"

                if check(test, "O"):

                    move = i
                    break

    # 3. CENTER
    if move is None and board[4] == " ":
        move = 4

    # 4. CORNERS
    if move is None:

        corners = []

        for i in [0,2,6,8]:

            if board[i] == " ":
                corners.append(i)

        if corners:
            move = random.choice(corners)

    # 5. ANY EMPTY
    if move is None:

        empty = []

        for i in range(9):

            if board[i] == " ":
                empty.append(i)

        if empty:
            move = random.choice(empty)

    # BOT MOVE
    if move is not None:
        board[move] = "X"

    # BOT WIN
    if check(board, "X"):

        await q.edit_message_text(
            "🤖 BOT WIN"
        )

        del bot_games[uid]

        return

    # DRAW
    if " " not in board:

        await q.edit_message_text(
            "🤝 MATCH DRAW"
        )

        del bot_games[uid]

        return

    # UPDATE BOARD
    await q.edit_message_reply_markup(
        reply_markup=board_ui(board, "bot")
    )

