async def join_game(update: Update, context):

    q = update.callback_query
    await q.answer()

    uid = q.from_user.id

    room_id = int(q.data.split("_")[1])

    if room_id not in rooms:
        return

    room = rooms[room_id]

    if room["player2"] is not None:
        return

    if uid == room["player1"]:
        return

    bal = cur.execute(
        "SELECT balance FROM users WHERE user_id=?",
        (uid,)
    ).fetchone()[0]

    if bal < 1:

        await q.message.reply_text(
            "❌ Need ₹1 Balance"
        )

        return

    # CUT BALANCE
    cur.execute(
        "UPDATE users SET balance=balance-1 WHERE user_id=?",
        (room["player1"],)
    )

    cur.execute(
        "UPDATE users SET balance=balance-1 WHERE user_id=?",
        (uid,)
    )

    conn.commit()

    room["player2"] = uid

    text = f"""
🎮 OX GAME START

🆔 ROOM : {room_id}

⭕ Player1 = O
❌ Player2 = X

🏆 Winner Reward : ₹2
⏰ Auto Move : 10 Sec
"""

    m1 = await context.bot.send_message(
        room["player1"],
        text,
        reply_markup=board_ui(
            room["board"],
            f"room_{room_id}"
        )
    )

    m2 = await context.bot.send_message(
        room["player2"],
        text,
        reply_markup=board_ui(
            room["board"],
            f"room_{room_id}"
        )
    )

    room["msg1"] = m1.message_id
    room["msg2"] = m2.message_id

    # START TIMER
    asyncio.create_task(
        auto_move(room_id, context)
    )

# =========================================================
#                    OX ROOM MOVE
# =========================================================

async def room_move(update: Update, context):

    q = update.callback_query
    await q.answer()

    uid = q.from_user.id

    data = q.data.split("_")

    room_id = int(data[1])
    pos = int(data[2])

    if room_id not in rooms:
        return

    room = rooms[room_id]

    if room["turn"] != uid:

        await q.answer(
            "❌ Wait Your Turn",
            show_alert=True
        )

        return

    board = room["board"]

    if board[pos] != " ":
        return

    symbol = "O"

    if uid == room["player2"]:
        symbol = "X"

    board[pos] = symbol

    # ================= WIN =================

    if check(board, symbol):

        cur.execute(
            "UPDATE users SET balance=balance+2 WHERE user_id=?",
            (uid,)
        )

        conn.commit()

        loser = room["player1"]

        if uid == room["player1"]:
            loser = room["player2"]

        await context.bot.send_message(
            uid,
            "🎉 YOU WIN ₹2"
        )

        await context.bot.send_message(
            loser,
            "❌ YOU LOSE"
        )

        del rooms[room_id]

        return

    # ================= DRAW =================

    if " " not in board:

        cur.execute(
            "UPDATE users SET balance=balance+1 WHERE user_id=?",
            (room["player1"],)
        )

        cur.execute(
            "UPDATE users SET balance=balance+1 WHERE user_id=?",
            (room["player2"],)
        )

        conn.commit()

        await context.bot.send_message(
            room["player1"],
            "🤝 MATCH DRAW\n💰 ₹1 Refund"
        )

        await context.bot.send_message(
            room["player2"],
            "🤝 MATCH DRAW\n💰 ₹1 Refund"
        )

        del rooms[room_id]

        return

    # ================= TURN CHANGE =================

    if uid == room["player1"]:
        room["turn"] = room["player2"]

    else:
        room["turn"] = room["player1"]

    # ================= BOARD UPDATE =================

    await context.bot.edit_message_reply_markup(
        chat_id=room["player1"],
        message_id=room["msg1"],
        reply_markup=board_ui(
            board,
            f"room_{room_id}"
        )
    )

    await context.bot.edit_message_reply_markup(
        chat_id=room["player2"],
        message_id=room["msg2"],
        reply_markup=board_ui(
            board,
            f"room_{room_id}"
        )
    )

# =========================================================
#                    AUTO MOVE TIMER
# =========================================================

async def auto_move(room_id, context):

    while room_id in rooms:

        await asyncio.sleep(10)

        if room_id not in rooms:
            return

        room = rooms[room_id]

        board = room["board"]

        # EMPTY BOX
        empty = []

        for i in range(9):

            if board[i] == " ":
                empty.append(i)

        if len(empty) == 0:
            return

        # CURRENT PLAYER
        current_player = room["turn"]

        # RANDOM MOVE
        pos = random.choice(empty)

        # SYMBOL
        symbol = "O"

        if current_player == room["player2"]:
            symbol = "X"

        # AUTO PLACE
        board[pos] = symbol

        # ================= WIN =================

        if check(board, symbol):

            cur.execute(
                "UPDATE users SET balance=balance+2 WHERE user_id=?",
                (current_player,)
            )

            conn.commit()

            loser = room["player1"]

            if current_player == room["player1"]:
                loser = room["player2"]

            await context.bot.send_message(
                current_player,
                "🎉 TIME OUT WIN ₹2"
            )

            await context.bot.send_message(
                loser,
                "❌ TIME OUT LOSE"
            )

            # FINAL BOARD
            await context.bot.edit_message_reply_markup(
                chat_id=room["player1"],
                message_id=room["msg1"],
                reply_markup=board_ui(
                    board,
                    f"room_{room_id}"
                )
            )

            await context.bot.edit_message_reply_markup(
                chat_id=room["player2"],
                message_id=room["msg2"],
                reply_markup=board_ui(
                    board,
                    f"room_{room_id}"
                )
            )

            del rooms[room_id]

            return

        # ================= DRAW =================

        if " " not in board:

            cur.execute(
                "UPDATE users SET balance=balance+1 WHERE user_id=?",
                (room["player1"],)
            )

            cur.execute(
                "UPDATE users SET balance=balance+1 WHERE user_id=?",
                (room["player2"],)
            )

            conn.commit()

            await context.bot.send_message(
                room["player1"],
                "🤝 MATCH DRAW"
            )

            await context.bot.send_message(
                room["player2"],
                "🤝 MATCH DRAW"
            )

            del rooms[room_id]

            return

        # ================= CHANGE TURN =================

        if current_player == room["player1"]:

            room["turn"] = room["player2"]

        else:

            room["turn"] = room["player1"]

        # ================= UPDATE BOARD =================

        await context.bot.edit_message_reply_markup(
            chat_id=room["player1"],
            message_id=room["msg1"],
            reply_markup=board_ui(
                board,
                f"room_{room_id}"
            )
        )

        await context.bot.edit_message_reply_markup(
            chat_id=room["player2"],
            message_id=room["msg2"],
            reply_markup=board_ui(
                board,
                f"room_{room_id}"
            )
        )

