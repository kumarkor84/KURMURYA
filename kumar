# ================= BOT MOVE =================
async def bot_move(update: Update, context):

    q = update.callback_query
    await q.answer()

    uid = q.from_user.id

    if uid not in bot_games:
        return

    board = bot_games[uid]

    pos = int(q.data.split("_")[1])

    if board[pos] != " ":
        return

    # USER MOVE
    board[pos] = "O"

    # USER WIN
    if check(board,"O"):

        await q.edit_message_text(
            """
🎉 YOU WIN

💰 Reward : ₹0
"""
        )

        del bot_games[uid]
        return

    # BOT MOVE
    empty = []

    for i in range(9):

        if board[i] == " ":
            empty.append(i)

    if empty:

        move = random.choice(empty)

        board[move] = "X"

    # BOT WIN
    if check(board,"X"):

        await q.edit_message_text(
            "🤖 BOT WIN"
        )

        del bot_games[uid]
        return

    # DRAW
    if " " not in board:

        await q.edit_message_text(
            "🤝 MATCH DRAW"
        )

        del bot_games[uid]
        return

    await q.edit_message_reply_markup(
        reply_markup=board_ui(board,"bot")
    )

