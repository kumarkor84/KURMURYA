async def withdraw(update: Update, context):

    if "withdraw" not in context.user_data:
        return

    if not update.message.text.isdigit():

        await update.message.reply_text(
            "❌ Send Valid Number"
        )

        return

    amount = int(update.message.text)

    user_id = update.effective_user.id

    # BALANCE CHECK
    data = cur.execute(
        "SELECT balance,wallet FROM users WHERE user_id=?",
        (user_id,)
    ).fetchone()

    balance = data[0]
    wallet = data[1]

    if amount > balance:

        await update.message.reply_text(
            "❌ Low Balance"
        )

        return

    # BALANCE CUT
    cur.execute(
        "UPDATE users SET balance=balance-? WHERE user_id=?",
        (amount, user_id)
    )

    conn.commit()

    # ADMIN BUTTON
    keyboard = InlineKeyboardMarkup([
        [
            InlineKeyboardButton(
                "✅ Accept",
                callback_data=f"accept_{user_id}_{amount}"
            ),

            InlineKeyboardButton(
                "❌ Reject",
                callback_data=f"reject_{user_id}_{amount}"
            )
        ]
    ])

    await context.bot.send_message(
        ADMIN_ID,
        f"""
💸 New Withdraw Request

👤 User : {user_id}
💰 Amount : ₹{amount}
🏦 Wallet : {wallet}
        """,
        reply_markup=keyboard
    )

    await update.message.reply_text(
        "✅ Withdraw Request Sent"
    )

    context.user_data["withdraw"] = False

