# =====================================================
    #                    ADMIN ADD
    # =====================================================

    if context.user_data.get("admin_add"):

        if uid != ADMIN_ID:
            return

        try:

            user_id, amount = txt.split()

            user_id = int(user_id)
            amount = int(amount)

            cur.execute(
                "UPDATE users SET balance=balance+? WHERE user_id=?",
                (amount, user_id)
            )

            conn.commit()

            await update.message.reply_text(
                f"✅ Added ₹{amount} To {user_id}"
            )

        except:

            await update.message.reply_text(
                "❌ Format : userid amount"
            )

        context.user_data["admin_add"] = False

        return

    # =====================================================
    #                    ADMIN CUT
    # =====================================================

    if context.user_data.get("admin_cut"):

        if uid != ADMIN_ID:
            return

        try:

            user_id, amount = txt.split()

            user_id = int(user_id)
            amount = int(amount)

            cur.execute(
                "UPDATE users SET balance=balance-? WHERE user_id=?",
                (amount, user_id)
            )

            conn.commit()

            await update.message.reply_text(
                f"✅ Cut ₹{amount} From {user_id}"
            )

        except:

            await update.message.reply_text(
                "❌ Format : userid amount"
            )

        context.user_data["admin_cut"] = False

        return

    # =====================================================
    #                    SAVE WALLET
    # =====================================================

    if context.user_data.get("wallet"):

        cur.execute(
            "UPDATE users SET wallet=? WHERE user_id=?",
            (txt, uid)
        )

        conn.commit()

        context.user_data["wallet"] = False

        await update.message.reply_text(
            "✅ Wallet Saved"
        )

        return

# =====================================================
    #                    WITHDRAW SYSTEM
    # =====================================================

    if context.user_data.get("withdraw"):

        if not txt.isdigit():

            await update.message.reply_text(
                "❌ Send Valid Number"
            )

            return

        amount = int(txt)

        data = cur.execute(
            "SELECT balance,wallet FROM users WHERE user_id=?",
            (uid,)
        ).fetchone()

        balance_user = data[0]
        wallet = data[1]

        if amount > balance_user:

            await update.message.reply_text(
                "❌ Low Balance"
            )

            return

        if wallet is None:

            await update.message.reply_text(
                "❌ Save Wallet First"
            )

            return

        # CUT BALANCE
        cur.execute(
            "UPDATE users SET balance=balance-? WHERE user_id=?",
            (amount, uid)
        )

        conn.commit()

        try:

            # API PAYMENT
            url = f"https://ultra-pay.store/APIs/api?token={ULTRA_TOKEN}&key={ULTRA_KEY}&paytoNumber={wallet}&amount={amount}&comment=Withdraw"

            r = requests.get(url)

            print(r.status_code)
            print(r.text)

            # SUCCESS
            await update.message.reply_text(
                f"""
✅ Withdraw Success

💰 Amount : ₹{amount}
🏦 Wallet : {wallet}
                """
            )

        except Exception as e:

            # REFUND
            cur.execute(
                "UPDATE users SET balance=balance+? WHERE user_id=?",
                (amount, uid)
            )

            conn.commit()

            await update.message.reply_text(
                f"""
❌ Payment Failed

💰 Refund Added

{e}
                """
            )

        context.user_data["withdraw"] = False

        return

